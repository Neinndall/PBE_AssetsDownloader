<Window x:Class="PBE_AssetsDownloader.UI.Dialogs.WadComparisonResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:PBE_AssetsDownloader.UI.Dialogs"
        mc:Ignorable="d"
        Title="WAD Comparison Results" Height="600" Width="900">
    <DockPanel Margin="10">
        <Button Content="Save Results..." DockPanel.Dock="Bottom" Margin="0,10,0,0" Click="SaveButton_Click"/>
        <TreeView x:Name="resultsTreeView" Style="{StaticResource ModernTreeView}">
            <!-- The TreeView will be populated from code-behind -->
        </TreeView>
    </DockPanel>
</Window>

